# Copy to ".env" to customise. All values are OPTIONAL (sensible defaults).

# Public base URL used when building short links.
BASE_URL=http://localhost:8000

# Storage: "memory" (zero-config) or "sqlite" (persistent across restarts).
STORAGE_BACKEND=memory
# SQLITE_PATH=shortlink.db

# Rate limiting (token bucket per client IP).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CAPACITY=20
RATE_LIMIT_REFILL_PER_SEC=5.0

# Hot-path read cache size.
CACHE_SIZE=1024
